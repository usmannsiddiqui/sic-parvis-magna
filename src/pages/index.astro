---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import HomeHero from '../components/HomeHero.astro';
---

<BaseLayout title="Sic Parvis Magna">
  <nav slot="header" class="site-nav">
    <a href="/" class="site-nav__brand">Sic Parvis Magna</a>
    <div class="site-nav__links">
      <a href="/writing" class="site-nav__link">Writing</a>
      <ThemeToggle />
    </div>
  </nav>

  <section class="intro">
    <p class="intro__lede">
      A commonplace book made public. Field notes on discipline, faith, and
      self-accountability.
    </p>
  </section>

  <HomeHero
    title="The Loop Invariant of Faith"
    meta="Oct 12, 2026 · 8 min read · Reflections"
    href="/writing"
  />
</BaseLayout>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 32px;
    gap: 16px;
  }
  .site-nav__brand {
    font-family: var(--font-serif);
    font-size: 23px;
    font-weight: 600;
    color: var(--text);
  }
  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 30px;
    font-family: var(--font-sans);
    font-size: 14px;
  }
  .site-nav__link {
    color: var(--text);
  }
  @media (max-width: 640px) {
    .site-nav {
      padding: 16px 20px;
      gap: 12px;
    }
    .site-nav__links {
      gap: 16px;
    }
    .site-nav__brand {
      font-size: 18px;
    }
  }

  .intro {
    max-width: 820px;
    margin: 34px auto 0;
    padding: 0 32px;
  }
  .intro__lede {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.72;
    color: var(--muted);
  }
  @media (max-width: 640px) {
    .intro {
      margin-top: 24px;
      padding: 0 20px;
    }
    .intro__lede {
      font-size: 18px;
    }
  }
</style>
