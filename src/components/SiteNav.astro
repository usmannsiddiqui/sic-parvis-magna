---
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="site-nav" aria-label="Primary">
  <a href="/" class="site-nav__brand">Sic Parvis Magna</a>
  <div class="site-nav__links">
    <a href="/writing" class="site-nav__link">Writing</a>
    <ThemeToggle />
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 32px;
    gap: 16px;
  }
  .site-nav__brand {
    font-family: var(--font-serif);
    font-size: 23px;
    font-weight: 600;
    color: var(--text);
  }
  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 30px;
    font-family: var(--font-sans);
    font-size: 14px;
  }
  .site-nav__link {
    color: var(--text);
  }
  @media (max-width: 640px) {
    .site-nav {
      padding: 16px 20px;
      gap: 12px;
    }
    .site-nav__links {
      gap: 16px;
    }
    .site-nav__brand {
      font-size: 18px;
    }
  }
</style>
